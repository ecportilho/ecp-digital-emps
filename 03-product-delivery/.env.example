# ECP Emps — Variáveis de Ambiente
# Copiar para .env — NUNCA commitar

# Servidor
PORT=3334
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# JWT (MESMA chave do ecp-digital-bank para compartilhar sessão) — OBRIGATORIO
JWT_SECRET=ecp-digital-bank-dev-secret-mude-em-producao

# Banco de Dados PJ
DATABASE_PATH=./database-emps.sqlite

# CORS
CORS_ORIGIN=http://localhost:5175

# Referência ao ecp-digital-bank (PF) para integração
PF_API_URL=http://localhost:3333

# Front-end
VITE_API_URL=http://localhost:3334
VITE_PF_APP_URL=http://localhost:5173

# Integracao com ecp-digital-pay — OBRIGATORIO
ECP_PAY_URL=http://localhost:3335
ECP_PAY_API_KEY=ecp-emps-dev-key
# Secret compartilhado com ECP Pay para autenticar POST /webhooks/payment-received
ECP_PAY_WEBHOOK_SECRET=ecp-pay-webhook-secret-dev
